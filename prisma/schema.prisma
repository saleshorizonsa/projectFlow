generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleName {
  ADMIN
  PROJECT_MANAGER
  TEAM_MEMBER
  VIEWER
}

enum ProjectStatus {
  DRAFT
  PLANNING
  PREPARATION
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LayerType {
  PLANNING
  PREPARATION
  IMPLEMENTATION
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  REVIEW
  COMPLETED
}

enum TaskType {
  PROJECT
  GENERAL
}

enum MilestoneStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  DELAYED
}

enum GapSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GapStatus {
  OPEN
  INVESTIGATING
  ACTION_PLANNED
  IN_PROGRESS
  CLOSED
}

enum GapActionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  TASK_OVERDUE
  GAP_OVERDUE
  MILESTONE_MISSED
  PROJECT_DELAYED
  SUPPORT_TICKET
  SLA_BREACH
  LICENSE_EXPIRING
  ASSET_LIFECYCLE
  MAINTENANCE_DUE
  AUTOMATION
}

enum ITAssetType {
  SERVER
  ROUTER
  SWITCH
  FIREWALL
  STORAGE
  LAPTOP
  DESKTOP
  PRINTER
  APPLICATION
  DATABASE
  CLOUD_SERVICE
  OTHER
}

enum ITAssetStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
  PLANNED_REPLACEMENT
}

enum ITMaintenanceStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  EXITED
}

enum SupportTicketStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum SupportTicketSource {
  PORTAL
  WHATSAPP
  PHONE
  EMAIL
}

enum SupportTicketCategory {
  HARDWARE
  SOFTWARE
  NETWORK
  ACCESS
  EMAIL
  ERP
  LICENSE
  MAINTENANCE
  OTHER
}

enum SupportTicketDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum AlertChannel {
  EMAIL
  WHATSAPP
}

enum AlertDeliveryStatus {
  SKIPPED
  SENT
  FAILED
}

enum ResourceAllocationStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum RiskTreatment {
  ACCEPT
  MITIGATE
  TRANSFER
  AVOID
}

enum VulnSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL
}

enum VulnStatus {
  OPEN
  IN_PROGRESS
  REMEDIATED
  ACCEPTED_RISK
  FALSE_POSITIVE
}

enum BackupFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum BackupStatus {
  SUCCESS
  PARTIAL
  FAILED
  UNKNOWN
}

enum PolicyStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  DEPRECATED
}

enum AcknowledgementStatus {
  PENDING
  ACKNOWLEDGED
  DECLINED
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  REPORTED
  INVESTIGATING
  CONTAINED
  ERADICATED
  RECOVERED
  CLOSED
}

enum IncidentType {
  DATA_BREACH
  RANSOMWARE
  PHISHING
  DDOS
  UNAUTHORIZED_ACCESS
  MALWARE
  INSIDER_THREAT
  PHYSICAL_SECURITY
  SYSTEM_OUTAGE
  OTHER
}

enum RiskStatus {
  OPEN
  UNDER_TREATMENT
  RESIDUAL
  CLOSED
}

enum ControlStatus {
  NOT_ASSESSED
  COMPLIANT
  PARTIALLY_COMPLIANT
  NON_COMPLIANT
  NOT_APPLICABLE
}

enum FindingSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ACCEPTED
  CLOSED
}

model User {
  id                      String                @id @default(cuid())
  name                    String
  email                   String                @unique
  phone                   String?
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?
  roleId                  String
  role                    Role                  @relation(fields: [roleId], references: [id])
  managedProjects         Project[]             @relation("ProjectManager")
  currentStateAssessments ProjectCurrentState[] @relation("CurrentStateAssessor")
  companies               UserCompany[]
  assignedAssets          ITAsset[]             @relation("AssetCustodian")
  assignedTasks           Task[]                @relation("TaskAssignee")
  ownedGaps               Gap[]                 @relation("GapOwner")
  gapActions              GapAction[]           @relation("ActionResponsible")
  assignedMaintenance     ITMaintenance[]       @relation("MaintenanceResponsible")
  assignedSupportTickets  SupportTicket[]       @relation("SupportTicketAssignee")
  supportTicketEvents     SupportTicketEvent[]  @relation("SupportTicketEventAuthor")
  comments                Comment[]             @relation("CommentAuthor")
  resourceAllocations     ResourceAllocation[]  @relation("ResourceAllocationUser")
  ownedRisks              Risk[]                @relation("RiskOwner")
  responsibleControls     ComplianceControl[]   @relation("ControlResponsible")
  uploadedEvidences       ControlEvidence[]     @relation("EvidenceUploader")
  auditFindings           AuditFinding[]        @relation("FindingResponsible")
  assignedVulnerabilities Vulnerability[]       @relation("VulnAssignee")
  approvedPolicies        Policy[]              @relation("PolicyApprover")
  assignedIncidents       Incident[]            @relation("IncidentAssignee")
  incidentTimelines       IncidentTimeline[]    @relation("IncidentTimelineAuthor")
  pirReviews              PostIncidentReview[]  @relation("PIRReviewer")
  notifications           Notification[]
  alertDeliveries         AlertDelivery[]
  accounts                Account[]
  sessions                Session[]
  failedLoginAttempts     Int                   @default(0)
  lockedUntil             DateTime?
  lastLoginAt             DateTime?
  lastLoginIp             String?
  mfaSecret               String?
  mfaEnabled              Boolean               @default(false)
  mfaBackupCodes          String[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  createdBy               String?
  updatedBy               String?
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  detail    Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?
}

model ITAsset {
  id             String           @id @default(cuid())
  assetTag       String           @unique
  name           String
  type           ITAssetType
  vendor         String
  model          String
  location       String
  purchaseDate   DateTime
  warrantyExpiry DateTime?
  lifecycleYears Int              @default(5)
  status         ITAssetStatus    @default(ACTIVE)
  assignedToId   String?
  assignedTo     User?            @relation("AssetCustodian", fields: [assignedToId], references: [id], onDelete: SetNull)
  employeeId     String?
  employee       Employee?        @relation("EmployeeAssets", fields: [employeeId], references: [id], onDelete: SetNull)
  notes          String?
  companies      ITAssetCompany[]
  maintenances    ITMaintenance[]
  licenses        ITLicense[]
  supportTickets  SupportTicket[]
  risks           Risk[]
  vulnerabilities Vulnerability[]
  backupJobs      BackupJob[]
  incidents       IncidentAsset[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdBy      String?
  updatedBy      String?

  @@index([status])
  @@index([assignedToId])
}

model ITAssetCompany {
  id        String   @id @default(cuid())
  assetId   String
  asset     ITAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([assetId, companyId])
}

model ITMaintenance {
  id                  String               @id @default(cuid())
  maintenanceId       String               @unique
  title               String
  description         String
  assetId             String
  asset               ITAsset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  scheduledAt         DateTime
  durationMinutes     Int
  status              ITMaintenanceStatus  @default(PLANNED)
  responsibleId       String
  responsible         User                 @relation("MaintenanceResponsible", fields: [responsibleId], references: [id])
  downtimeRequired    Boolean              @default(false)
  resourceAllocations ResourceAllocation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  createdBy           String?
  updatedBy           String?

  @@index([scheduledAt])
  @@index([status])
  @@index([assetId])
}

model ITLicense {
  id             String          @id @default(cuid())
  licenseId      String          @unique
  name           String
  vendor         String
  assetId        String?
  asset          ITAsset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  seats          Int             @default(1)
  cost           Decimal         @default(0) @db.Decimal(14, 2)
  expiryDate     DateTime
  owner          String
  employeeId     String?
  employee       Employee?       @relation("EmployeeLicenses", fields: [employeeId], references: [id], onDelete: SetNull)
  supportTickets SupportTicket[]
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdBy      String?
  updatedBy      String?

  @@index([expiryDate])
}

model Employee {
  id             String            @id @default(cuid())
  employeeId     String            @unique
  name           String
  email          String?
  phone          String?
  department     String
  jobTitle       String
  location       String?
  photoUrl       String?
  status         EmployeeStatus    @default(ACTIVE)
  ipAddress      String?
  vpnUserId      String?
  vpnPassword      String?
  leaveStartDate   DateTime?
  leaveReturnDate  DateTime?
  leaveReason      String?
  exitDate         DateTime?
  offboardingNotes String?
  companies        EmployeeCompany[]
  assets         ITAsset[]               @relation("EmployeeAssets")
  policyAcknowledgements PolicyAcknowledgement[]
  licenses       ITLicense[]       @relation("EmployeeLicenses")
  supportTickets SupportTicket[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdBy      String?
  updatedBy      String?
}

model EmployeeCompany {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?

  @@unique([employeeId, companyId])
}

model Company {
  id             String            @id @default(cuid())
  code           String            @unique
  name           String
  description    String?
  active         Boolean           @default(true)
  logoUrl        String?
  projects       ProjectCompany[]
  assets         ITAssetCompany[]
  users          UserCompany[]
  employees      EmployeeCompany[]
  supportTickets  SupportTicket[]
  incidents       Incident[]
  playbooks       IncidentPlaybook[]
  risks           Risk[]
  vulnerabilities Vulnerability[]
  backupJobs      BackupJob[]
  policies        Policy[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       String?
  updatedBy       String?
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([userId, companyId])
}

model ProjectCompany {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([projectId, companyId])
}

model Project {
  id                  String               @id @default(cuid())
  projectId           String               @unique
  name                String
  description         String
  client              String
  startDate           DateTime
  endDate             DateTime
  status              ProjectStatus        @default(DRAFT)
  priority            Priority             @default(MEDIUM)
  budget              Decimal              @db.Decimal(14, 2)
  managerId           String
  manager             User                 @relation("ProjectManager", fields: [managerId], references: [id])
  companies           ProjectCompany[]
  currentState        ProjectCurrentState?
  layers              ProjectLayer[]
  tasks               Task[]
  milestones          Milestone[]
  gaps                Gap[]
  comments            Comment[]
  attachments         Attachment[]
  resourceAllocations ResourceAllocation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  createdBy           String?
  updatedBy           String?
}

model ProjectCurrentState {
  id              String   @id @default(cuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  summary         String
  currentProcess  String
  tools           String
  resources       String
  painPoints      String
  risks           String
  constraints     String
  assessmentDate  DateTime
  assessedById    String
  assessedBy      User     @relation("CurrentStateAssessor", fields: [assessedById], references: [id])
  confidenceLevel Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
}

model ProjectLayer {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type       LayerType
  name       String
  completion Int        @default(0)
  subLayers  SubLayer[]
  tasks      Task[]
  gaps       Gap[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  createdBy  String?
  updatedBy  String?

  @@unique([projectId, type])
}

model SubLayer {
  id        String       @id @default(cuid())
  layerId   String
  layer     ProjectLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)
  name      String
  order     Int
  tasks     Task[]
  gaps      Gap[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([layerId, name])
}

model Task {
  id                  String               @id @default(cuid())
  taskType            TaskType             @default(PROJECT)
  title               String
  description         String
  projectId           String?
  project             Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layerId             String?
  layer               ProjectLayer?        @relation(fields: [layerId], references: [id])
  subLayerId          String?
  subLayer            SubLayer?            @relation(fields: [subLayerId], references: [id])
  priority            Priority             @default(MEDIUM)
  assigneeId          String
  assignee            User                 @relation("TaskAssignee", fields: [assigneeId], references: [id])
  startDate           DateTime?
  dueDate             DateTime
  estimatedHours      Decimal              @db.Decimal(8, 2)
  actualHours         Decimal              @default(0) @db.Decimal(8, 2)
  status              TaskStatus           @default(NOT_STARTED)
  parentTaskId        String?
  parent              Task?                @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks            Task[]               @relation("TaskSubtasks")
  comments            Comment[]
  attachments         Attachment[]
  resourceAllocations ResourceAllocation[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  createdBy           String?
  updatedBy           String?

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([parentTaskId])
}

model Milestone {
  id          String          @id @default(cuid())
  name        String
  description String
  dueDate     DateTime
  completion  Int             @default(0)
  status      MilestoneStatus @default(UPCOMING)
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String?
  updatedBy   String?

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

model Gap {
  id                String       @id @default(cuid())
  gapId             String       @unique
  title             String
  description       String
  projectId         String
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layerId           String
  layer             ProjectLayer @relation(fields: [layerId], references: [id])
  subLayerId        String?
  subLayer          SubLayer?    @relation(fields: [subLayerId], references: [id])
  severity          GapSeverity  @default(MEDIUM)
  impact            String
  rootCause         String
  ownerId           String
  owner             User         @relation("GapOwner", fields: [ownerId], references: [id])
  targetClosureDate DateTime
  status            GapStatus    @default(OPEN)
  actions           GapAction[]
  comments          Comment[]
  attachments       Attachment[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  createdBy         String?
  updatedBy         String?

  @@index([projectId])
  @@index([ownerId])
  @@index([status])
  @@index([severity])
  @@index([targetClosureDate])
}

model GapAction {
  id                String          @id @default(cuid())
  actionId          String          @unique
  gapId             String
  gap               Gap             @relation(fields: [gapId], references: [id], onDelete: Cascade)
  correctiveAction  String
  responsibleId     String
  responsiblePerson User            @relation("ActionResponsible", fields: [responsibleId], references: [id])
  dueDate           DateTime
  status            GapActionStatus @default(PLANNED)
  progress          Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         String?
  updatedBy         String?

  @@index([gapId])
  @@index([responsibleId])
  @@index([status])
  @@index([dueDate])
}

model ResourceAllocation {
  id                String                   @id @default(cuid())
  userId            String
  user              User                     @relation("ResourceAllocationUser", fields: [userId], references: [id], onDelete: Cascade)
  title             String
  projectId         String?
  project           Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId            String?
  task              Task?                    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  maintenanceId     String?
  maintenance       ITMaintenance?           @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)
  startAt           DateTime
  endAt             DateTime
  allocationPercent Int                      @default(100)
  status            ResourceAllocationStatus @default(PLANNED)
  notes             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  createdBy         String?
  updatedBy         String?

  @@index([userId])
  @@index([startAt])
  @@index([endAt])
}

model SupportTicket {
  id                 String                @id @default(cuid())
  ticketNo           String                @unique
  title              String
  description        String
  companyId          String
  company            Company               @relation(fields: [companyId], references: [id])
  employeeId         String?
  employee           Employee?             @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  assetId            String?
  asset              ITAsset?              @relation(fields: [assetId], references: [id], onDelete: SetNull)
  licenseId          String?
  license            ITLicense?            @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  category           SupportTicketCategory @default(OTHER)
  priority           Priority              @default(MEDIUM)
  status             SupportTicketStatus   @default(OPEN)
  source             SupportTicketSource   @default(PORTAL)
  requesterName      String?
  requesterPhone     String?
  whatsappFrom       String?
  whatsappMessageId  String?
  assignedToId       String?
  assignedTo         User?                 @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  firstResponseDueAt DateTime?
  resolveDueAt       DateTime?
  respondedAt        DateTime?
  slaBreached        Boolean               @default(false)
  escalatedAt        DateTime?
  resolvedAt         DateTime?
  events             SupportTicketEvent[]
  comments           Comment[]
  attachments        Attachment[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdBy          String?
  updatedBy          String?

  @@index([companyId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([resolveDueAt])
}

model SupportTicketEvent {
  id                String                 @id @default(cuid())
  ticketId          String
  ticket            SupportTicket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body              String
  direction         SupportTicketDirection @default(INTERNAL)
  source            SupportTicketSource    @default(PORTAL)
  whatsappMessageId String?
  authorId          String?
  author            User?                  @relation("SupportTicketEventAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  createdBy         String?
  updatedBy         String?
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  message    String
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  createdBy  String?
  updatedBy  String?
  deliveries AlertDelivery[]

  @@index([userId])
  @@index([readAt])
  @@index([type])
}

model AlertDelivery {
  id             String              @id @default(cuid())
  notificationId String?
  notification   Notification?       @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  userId         String?
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel        AlertChannel
  recipient      String
  title          String
  message        String
  provider       String?
  status         AlertDeliveryStatus @default(SKIPPED)
  error          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      String?
  updatedBy      String?

  @@index([notificationId])
  @@index([userId])
  @@index([status])
}

model Comment {
  id              String         @id @default(cuid())
  body            String
  authorId        String
  author          User           @relation("CommentAuthor", fields: [authorId], references: [id])
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId          String?
  task            Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  gapId           String?
  gap             Gap?           @relation(fields: [gapId], references: [id], onDelete: Cascade)
  supportTicketId String?
  supportTicket   SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String?
  updatedBy       String?
}

model Attachment {
  id              String         @id @default(cuid())
  fileName        String
  fileUrl         String
  mimeType        String
  size            Int
  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId          String?
  task            Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  gapId           String?
  gap             Gap?           @relation(fields: [gapId], references: [id], onDelete: Cascade)
  supportTicketId String?
  supportTicket   SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String?
  updatedBy       String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model ComplianceFramework {
  id          String             @id @default(cuid())
  code        String             @unique
  name        String
  version     String?
  description String?
  domains     ComplianceDomain[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   String?
  updatedBy   String?
}

model ComplianceDomain {
  id          String              @id @default(cuid())
  code        String
  name        String
  description String?
  order       Int                 @default(0)
  frameworkId String
  framework   ComplianceFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  controls    ComplianceControl[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([frameworkId, code])
  @@index([frameworkId])
}

model ComplianceControl {
  id                  String            @id @default(cuid())
  controlId           String            @unique
  title               String
  description         String?
  objective           String?
  domainId            String
  domain              ComplianceDomain  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status              ControlStatus     @default(NOT_ASSESSED)
  implementationNotes String?
  responsibleId       String?
  responsible         User?             @relation("ControlResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  lastAssessedAt      DateTime?
  nextReviewAt        DateTime?
  evidences           ControlEvidence[]
  findings            AuditFinding[]
  risks               Risk[]
  policyMappings      PolicyControl[]
  vulnerabilities     Vulnerability[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  createdBy           String?
  updatedBy           String?

  @@index([domainId])
  @@index([status])
}

model ControlEvidence {
  id           String            @id @default(cuid())
  controlId    String
  control      ComplianceControl @relation(fields: [controlId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  mimeType     String?
  size         Int?
  notes        String?
  uploadedById String
  uploadedBy   User              @relation("EvidenceUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdBy    String?
  updatedBy    String?

  @@index([controlId])
}

model Risk {
  id                 String             @id @default(cuid())
  riskId             String             @unique
  title              String
  description        String
  category           String
  likelihood         Int
  impact             Int
  riskScore          Int
  treatment          RiskTreatment      @default(MITIGATE)
  treatmentPlan      String?
  residualLikelihood Int?
  residualImpact     Int?
  residualScore      Int?
  status             RiskStatus         @default(OPEN)
  ownerId            String
  owner              User               @relation("RiskOwner", fields: [ownerId], references: [id])
  assetId            String?
  asset              ITAsset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)
  controlId          String?
  control            ComplianceControl? @relation(fields: [controlId], references: [id], onDelete: SetNull)
  dueDate            DateTime?
  closedAt           DateTime?
  companyId          String?
  company            Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  notes              String?
  incidents          IncidentRisk[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  createdBy          String?
  updatedBy          String?

  @@index([status])
  @@index([ownerId])
  @@index([riskScore])
}

model AuditFinding {
  id            String             @id @default(cuid())
  findingId     String             @unique
  title         String
  description   String
  severity      FindingSeverity
  status        FindingStatus      @default(OPEN)
  controlId     String?
  control       ComplianceControl? @relation(fields: [controlId], references: [id], onDelete: SetNull)
  responsibleId String?
  responsible   User?              @relation("FindingResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  dueDate       DateTime?
  closedAt      DateTime?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  createdBy     String?
  updatedBy     String?

  @@index([status])
  @@index([severity])
  @@index([controlId])
}

model Vulnerability {
  id                String             @id @default(cuid())
  vulnId            String             @unique
  title             String
  cveId             String?
  description       String
  severity          VulnSeverity
  cvssScore         Decimal?           @db.Decimal(4, 1)
  status            VulnStatus         @default(OPEN)
  affectedComponent String?
  source            String?
  remediation       String?
  dueDate           DateTime?
  closedAt          DateTime?
  discoveredAt      DateTime           @default(now())
  assetId           String?
  asset             ITAsset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignedToId      String?
  assignedTo        User?              @relation("VulnAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  controlId         String?
  control           ComplianceControl? @relation(fields: [controlId], references: [id], onDelete: SetNull)
  companyId         String?
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  notes             String?
  incidents         IncidentVulnerability[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdBy         String?
  updatedBy         String?

  @@index([status])
  @@index([severity])
  @@index([assetId])
  @@index([dueDate])
}

model BackupJob {
  id            String          @id @default(cuid())
  jobId         String          @unique
  name          String
  assetId       String?
  asset         ITAsset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  frequency     BackupFrequency @default(DAILY)
  rpoHours      Int             @default(24)
  retentionDays Int             @default(30)
  lastRunAt     DateTime?
  lastStatus    BackupStatus    @default(UNKNOWN)
  lastSizeBytes BigInt?
  nextRunAt     DateTime?
  isActive      Boolean         @default(true)
  notes         String?
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  logs          BackupLog[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdBy     String?
  updatedBy     String?

  @@index([isActive])
  @@index([lastStatus])
}

model BackupLog {
  id              String       @id @default(cuid())
  jobId           String
  job             BackupJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status          BackupStatus
  startedAt       DateTime
  completedAt     DateTime?
  durationMinutes Int?
  sizeBytes       BigInt?
  errorMessage    String?
  createdAt       DateTime     @default(now())

  @@index([jobId])
  @@index([startedAt])
}

model Policy {
  id               String                  @id @default(cuid())
  policyId         String                  @unique
  title            String
  description      String?
  category         String
  status           PolicyStatus            @default(DRAFT)
  version          String                  @default("1.0")
  fileUrl          String?
  fileName         String?
  effectiveDate    DateTime?
  reviewDate       DateTime?
  approverId       String?
  approver         User?                   @relation("PolicyApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  companyId        String?
  company          Company?                @relation(fields: [companyId], references: [id], onDelete: SetNull)
  versions         PolicyVersion[]
  acknowledgements PolicyAcknowledgement[]
  controls         PolicyControl[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  createdBy        String?
  updatedBy        String?

  @@index([status])
  @@index([category])
  @@index([reviewDate])
}

model PolicyVersion {
  id          String   @id @default(cuid())
  policyId    String
  policy      Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  version     String
  fileUrl     String
  fileName    String
  notes       String?
  publishedAt DateTime @default(now())
  publishedBy String?

  @@index([policyId])
}

model PolicyAcknowledgement {
  id             String                @id @default(cuid())
  policyId       String
  policy         Policy                @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  status         AcknowledgementStatus @default(PENDING)
  sentAt         DateTime              @default(now())
  acknowledgedAt DateTime?
  ipAddress      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([policyId, employeeId])
  @@index([policyId])
  @@index([employeeId])
  @@index([status])
}

model PolicyControl {
  id        String            @id @default(cuid())
  policyId  String
  policy    Policy            @relation(fields: [policyId], references: [id], onDelete: Cascade)
  controlId String
  control   ComplianceControl @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@unique([policyId, controlId])
}

model Incident {
  id              String                  @id @default(cuid())
  incidentId      String                  @unique
  title           String
  description     String?
  type            IncidentType            @default(OTHER)
  severity        IncidentSeverity        @default(HIGH)
  status          IncidentStatus          @default(REPORTED)
  impact          String?
  rootCause       String?
  affectedSystems String?
  reportedAt      DateTime                @default(now())
  containedAt     DateTime?
  eradicatedAt    DateTime?
  recoveredAt     DateTime?
  closedAt        DateTime?
  assignedToId    String?
  assignedTo      User?                   @relation("IncidentAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  companyId       String?
  company         Company?                @relation(fields: [companyId], references: [id])
  timeline        IncidentTimeline[]
  review          PostIncidentReview?
  assets          IncidentAsset[]
  vulnerabilities IncidentVulnerability[]
  risks           IncidentRisk[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  createdBy       String?
  updatedBy       String?

  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([reportedAt])
}

model IncidentTimeline {
  id            String   @id @default(cuid())
  incidentId    String
  incident      Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  action        String
  detail        String?
  performedById String?
  performedBy   User?    @relation("IncidentTimelineAuthor", fields: [performedById], references: [id], onDelete: SetNull)
  occurredAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([incidentId])
}

model PostIncidentReview {
  id              String    @id @default(cuid())
  incidentId      String    @unique
  incident        Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  summary         String?
  timeline        String?
  rootCause       String?
  lessonsLearned  String?
  recommendations String?
  reviewedById    String?
  reviewedBy      User?     @relation("PIRReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model IncidentPlaybook {
  id          String       @id @default(cuid())
  playbookId  String       @unique
  title       String
  type        IncidentType @default(OTHER)
  description String?
  steps       Json
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   String?
  updatedBy   String?
}

model IncidentAsset {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  assetId    String
  asset      ITAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([incidentId, assetId])
}

model IncidentVulnerability {
  id              String        @id @default(cuid())
  incidentId      String
  incident        Incident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  vulnerabilityId String
  vulnerability   Vulnerability @relation(fields: [vulnerabilityId], references: [id], onDelete: Cascade)

  @@unique([incidentId, vulnerabilityId])
}

model IncidentRisk {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  riskId     String
  risk       Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@unique([incidentId, riskId])
}
